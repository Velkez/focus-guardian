{
  "name": "focus-guardian",
  "version": "1.0.1",
  "description": "Browser extension that blocks distracting social media feeds",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"const fs=require('fs');const p=require('path');fs.copyFileSync('manifest.json','dist/manifest.json');function c(s,d){if(!fs.existsSync(s))return;if(!fs.existsSync(d))fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(e=>{const sp=s+'/'+e,dp=d+'/'+e;fs.statSync(sp).isDirectory()?c(sp,dp):fs.copyFileSync(sp,dp)})}c('alarms','dist/alarms')\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "package": "npm run build && zip -r dist/focus-guardian.zip dist/",
    "package:crx": "npm run build && crx pack dist -p focus-guardian.pem -o dist/focus-guardian.crx",
    "format": "prettier --write src/"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.11.0",
    "prettier": "^3.3.0",
    "vite": "^5.4.0",
    "web-ext": "^8.3.0",
    "crx": "^4.0.0"
  },
  "dependencies": {
    "i18next": "^23.15.0",
    "js-yaml": "^4.1.0"
  },
  "keywords": [
    "browser-extension",
    "pomodoro",
    "productivity",
    "focus"
  ],
  "license": "MIT"
}
